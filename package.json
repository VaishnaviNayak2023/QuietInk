{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "prepare-data": "py -m pip install -r requirements.txt && python scripts/prepare_data.py",
    "train-model": "python scripts/train_model.py",
    "evaluate-model": "python scripts/evaluate_model.py",
    "test": "tsx tests/run_tests.ts"
  },
  "dependencies": {
    "@firebase/eslint-plugin-security-rules": "^0.0.2",
    "@google/genai": "^2.3.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/crypto-js": "^4.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.13.0",
    "idb": "^8.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pdfkit": "^0.13.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
